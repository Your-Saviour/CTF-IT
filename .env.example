# Required — used for session signing and deterministic flag generation (HMAC)
SECRET_KEY=change-me-to-a-random-string

# Database URL — defaults to sqlite:///ctf.db, use a postgres URI for production
DATABASE_URL=sqlite:///ctf.db

# Module selection quota — controls how many modules of each type/difficulty are
# assigned per user. Adjust counts to shape the challenge set.
EVENT_QUOTA={"vulnerability":{"easy":1,"medium":1,"hard":0},"hardening":{"easy":1,"medium":1,"hard":0}}

# The default root password baked into the base image. The password_changed
# verification checks that users have changed it from this value.
ROOT_PASSWORD=changeme123

# User-facing address for the Docker registry (where users pull images from).
# Set to your LAN IP for remote access, e.g. 192.168.1.50:5050
# NOTE: The registry runs over HTTP. You must add this address to Docker's
# "insecure-registries" in /etc/docker/daemon.json and restart Docker.
# See README.md for details.
REGISTRY_HOST=localhost:5050

# Address the Docker daemon uses to push to the registry. Only change if running
# Docker-in-Docker instead of a socket-mounted setup.
# REGISTRY_PUSH_HOST=localhost:5050

# Host and port shown in the dashboard verify command (the address containers
# use to reach the API). Default is host.docker.internal:8000 which works for
# Docker Desktop. For LAN/VPS setups, set to the server's IP and port.
# API_HOST=host.docker.internal:8000
# API_HOST=192.168.1.50:8000

# Port the API is exposed on (default 8000)
# API_PORT=8000

# Target platform for Docker image builds. Set this when the build server and
# user machines have different architectures (e.g. building on AMD64 but users
# run on Apple Silicon Macs, or vice versa).
# DOCKER_PLATFORM=linux/arm64
# DOCKER_PLATFORM=linux/amd64

# Internal registry URL used by the API container (e.g. for admin cleanup).
# Only change if you renamed the registry service in docker-compose.yml.
# REGISTRY_INTERNAL=http://registry:5000
